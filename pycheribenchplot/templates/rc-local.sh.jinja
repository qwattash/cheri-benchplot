# Auto-generated by cheri-benchplot

. /etc/rc.subr

info "cheri-benchplot rc.local {{ session }}"

# Ensure that we have a kernel file, this is necessary for hwpmc
# in FPGA images
if [ ! -f /boot/kernel/kernel ]; then
    mkdir -p /boot/kernel
    touch /boot/kernel/kernel
fi

load_rc_config
: ${benchplot_enable:="NO"}
: ${benchplot_session:=""}
: ${benchplot_user:="root"}
: ${benchplot_settle_delay:=""}
: ${benchplot_reboot:="NO"}

if [ -n "${benchplot_settle_delay}" ]; then
    _delay_arg="-k ${benchplot_settle_delay}"
fi

autorun_script="${benchplot_session}/auto-run.sh"

if [ "${benchplot_enable}" = "NO" ]; then
    err 0 "Benchplot autorun disabled."
fi

if [ ! -d "${benchplot_session}" ]; then
	err 1 "${benchplot_session} is not a directory."
fi

if [ ! -x "${autorun_script}" ]; then
	err 1 "Autorun script '${autorun_script}' not found or not executable."
fi

info "Autorun benchplot session at ${benchplot_session}"
if [ "${benchplot_reboot}" = "NO" ]; then
    NOREBOOT="-n"
fi

# -n prevents auto-reboot
(cd ${benchplot_session} && ${autorun_script} ${NOREBOOT} ${_delay_arg})

if [ "${benchplot_reboot}" = "NO" ]; then
    # Introduce some delay to let output buffers drain before poweroff
    sleep 2
    poweroff
fi
