#!/bin/sh

set -e

usage() {
    echo "Run session across multiple targets on this machine"
    echo "-s Prepare the machine for autorun"
    echo "-t Cleaup the autorun init.d"
    echo "-n Do not trigger reboot"
    echo "-k <time> Use custom settle time, defaults to 5 seconds"
    echo "Usage: $0"
}

OPT_RC_SETUP=
OPT_RC_TEARDOWN=
OPT_NOREBOOT=

SESSION_WORKDIR="$(pwd)"
AUTORUN_PATH="${SESSION_WORKDIR}/$(basename '$0')"
AUTORUN_RC="/usr/local/etc/rc.d/benchplot"
SETTLE_TIME=5

HAS_BOOTENV="$(which bectl)"

while [ "$#" -gt 0 ]; do
    case $1 in
        -h)
            usage
            exit
            ;;
        -s)
            OPT_RC_SETUP=1
            ;;
        -t)
            OPT_RC_TEARDOWN=1
            ;;
        -n)
            OPT_NOREBOOT=1
            ;;
        -k)
            if [ -n "$2" ]; then
                SETTLE_TIME=$2
                shift
            else
                usage
                exit
            fi
            ;;
        *)
            usage
            exit
            ;;
    esac

    shift
done

ARCH="$(uname -m)"
KERNEL="$(uname -i)"
if [ -n "${HAS_BOOTENV}" ]; then
    ACTIVE_BE="$(bectl list -H | grep -E '[^[:blank:]]+\s+NR?T?' | cut -f1)"
    REBOOT_BE="$(bectl list -H | grep -E '[^[:blank:]]+\s+N?RT?' | cut -f1)"
fi

echo "##############################################"
echo "Benchplot auto-run: $0"
echo "User: $(whoami)"
echo "Workdir: ${SESSION_WORKDIR}"
echo "Settle time: ${SETTLE_TIME}"
echo "Arch: ${ARCH}"
echo "Kernel: ${KERNEL}"
echo "Bootenv: ${ACTIVE_BE}"
echo "##############################################"

# boot_kernel <bootenv> <kernel_name>
boot_kernel() {
    local bootenv="${1}"
    local kconf="${2}"

    if [ -n "${HAS_BOOTENV}" ]; then
        if [ -z "${bootenv}" ]; then
            echo "Using default bootenv ${REBOOT_BE}"
        elif [ "${bootenv}" = "${REBOOT_BE}" ]; then
            echo "Already rebooting into target bootenv ${bootenv}, skip activate"
        else
            echo "Activate target bootenv ${bootenv}"
            bectl activate -t "${bootenv}"
        fi

        echo "Update next boot kernel to kernel.${kconf}"
        if [ "${bootenv}" != "${ACTIVE_BE}" ]; then
            mkdir /tmp/be_mount
            bectl mount "${bootenv}" /tmp/be_mount > /dev/null
            echo "kernel=\"kernel.${kconf}\"" > /tmp/be_mount/boot/nextboot.conf
            bectl umount "${bootenv}"
            rmdir /tmp/be_mount
            # Ensure that the next boot will look for /boot/nextboot.conf
            zfsbootcfg -z ZROOT -n "freebsd:nvstore" -k "nextboot_enable" -v "YES"
        else
            nextboot {% if single_user %}-o "-s"{% endif %} -k "kernel.${kconf}"
        fi
    else
        if [ -n "${bootenv}" ]; then
            echo "WARNING: this configuration uses boot environments."
            echo "If this is intentional, use autorun.sh -n to disable auto reboot."
            exit 1
        fi
        nextboot {% if single_user %}-o "-s"{% endif %} -k "kernel.${kconf}"
    fi
}

setup_rc_conf() {
    local bootenv="$1"
    local rc_service="${AUTORUN_RC}"
    local rc_conf=""

    echo "Install autorun rc hook..."
    if [ -n "${bootenv}" ] && [ "${bootenv}" != "${ACTIVE_BE}" ]; then
        echo "Enter bootenv ${bootenv}"
        bectl mount "${bootenv}" /tmp/be_mount > /dev/null
        rc_service="/tmp/be_mount/${rc_service}"
        rc_conf="-f /tmp/be_mount/etc/rc.conf"
    fi

    cp "${SESSION_WORKDIR}/rc-autorun.sh" "${rc_service}"
    sysrc ${rc_conf} benchplot_enable="YES"
    sysrc ${rc_conf} benchplot_session="${SESSION_WORKDIR}"

    if [ -n "${bootenv}" ] && [ "${bootenv}" != "${ACTIVE_BE}" ]; then
        bectl umount "${bootenv}"
        echo "Exited bootenv ${bootenv}"
    fi
    echo "Done"
}

teardown_rc_conf() {
    local bootenv="$1"
    local rc_service="${AUTORUN_RC}"
    local rc_conf=""

    echo "Teardown autorun rc hook..."
    if [ -n "${bootenv}" ] && [ "${bootenv}" != "${ACTIVE_BE}" ]; then
        echo "Enter bootenv ${bootenv}"
        bectl mount "${bootenv}" /tmp/be_mount > /dev/null
        rc_service="/tmp/be_mount/${rc_service}"
        rc_conf="-f /tmp/be_mount/etc/rc.conf"
    fi

    if [ -f "${rc_service}" ]; then
        echo "Teardown autorun service ${rc_service}"
        rm "${rc_service}"
        sysrc ${rc_conf} -x benchplot_enable
        sysrc ${rc_conf} -x benchplot_session
    fi

    if [ -n "${bootenv}" ] && [ "${bootenv}" != "${ACTIVE_BE}" ]; then
        bectl umount "${bootenv}"
        echo "Exited bootenv ${bootenv}"
    fi
}

if [ -n "${OPT_RC_SETUP}" ]; then
    if [ -z "${HAS_BOOTENV}" ]; then
        # Install rc.local hook for the current system, skip bootenv handling "
        setup_rc_conf
    fi

    # Clear / create autorun logfile
    # Note that if sbin/daemon finds it here, it will retain the
    # current permission
    truncate -s 0 "${SESSION_WORKDIR}/auto-run.log"
    chmod 644 "${SESSION_WORKDIR}/auto-run.log"

    echo "Prepare kernel to boot..."
    case "${ARCH}" in
        {% for arch, run_info in autorun_info.items() %}
        {{ arch }})
            NEXT_KERNEL="{{ run_info[0]['instance'].kernel }}"
            NEXT_BE="{{ run_info[0]['instance'].bootenv }}"

            if [ -n "${HAS_BOOTENV}" ]; then
                # If we support boot environments, initialize the rc hook everywhere
                {% if run_info | map(attribute='instance') |
                     map(attribute='bootenv') | reject('none') |
                     list | length == 0 %}
                # No configured boot environment, use the default one
                echo "Install autorun rc hook for default bootenv ${ACTIVE_BE}"
                setup_rc_conf
                {% else %}
                # Initialize each boot environment present in the configuration
                mkdir /tmp/be_mount
                {% for bootenv in run_info | map(attribute='instance') |
                     map(attribute='bootenv') | unique | reject('none') %}
                setup_rc_conf "{{ bootenv }}"
                {% endfor %}
                rmdir /tmp/be_mount
                {% endif %}
            fi
            ;;
        {% endfor %}
        *)
            echo "Unexpected architecture ${ARCH}"
            exit 1
            ;;
    esac
    boot_kernel "${NEXT_BE}" "${NEXT_KERNEL}"
    echo "Done -- Reboot now to trigger auto-run sequence"
    exit 0
fi

if [ -n "${OPT_RC_TEARDOWN}" ]; then
    echo "Teardown autorun rc hooks..."
    if [ -n "${HAS_BOOTENV}" ]; then
        # Attempt to de-register autorun from all bootenvs
        mkdir /tmp/be_mount
        for bootenv in $(bectl list -H | cut -w -f1); do
            teardown_rc_conf "${bootenv}"
        done
        rmdir /tmp/be_mount
    else
        teardown_rc_conf
    fi
    echo "Done"
    exit 0
fi

# Determine next kernel to run and current workload run script
NEXT_KERNEL=
WORKLOAD_SCRIPT=
case "${ARCH}" in
    {% for arch, run_info in autorun_info.items() %}
    {{ arch }})
    case "${KERNEL}" in
        {% for info in run_info %}
        {{ info['instance'].kernel }})
            WORKLOAD_SCRIPT="{{ info['run_script'] }}"
            {% if loop.index < run_info|length %}
            NEXT_KERNEL="{{ run_info[loop.index]['instance'].kernel }}"
            NEXT_BE="{{ run_info[loop.index]['instance'].bootenv }}"
            {% endif %}
            ;;
        {% endfor %}
        *)
            # Undexpected kernel
            echo "Unexpected kernel encountered ${KERNEL}"
            exit 1
            ;;
    esac
    ;;
    {% endfor %}
    *)
        echo "Unexpected architecture ${ARCH}"
        exit 1
        ;;
esac

if [ -n "$WORKLOAD_SCRIPT" ]; then
    echo "Auto-run sequence ({{ session }}): workload ${WORKLOAD_SCRIPT}"
    echo "Waiting for system to settle"
    sleep ${SETTLE_TIME}
    echo "Run!"
    ${SESSION_WORKDIR}/${WORKLOAD_SCRIPT}
fi

if [ -n "${NEXT_KERNEL}" -a -z "${OPT_NOREBOOT}" ]; then
    echo "Prepare kernel to boot..."
    boot_kernel "${NEXT_BE}" "${NEXT_KERNEL}"
    echo "Reboot now!"
    reboot
fi
