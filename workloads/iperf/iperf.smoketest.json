{
    "version": "1.0",
    "benchmark_config": {
        "name": "iperf",
        "desc": "iperf3 smoketest",
        "iterations": 2,
        "parameterize": {
            "host": ["morello-hybrid", "morello-benchmark"],
            "bufsize": ["64", "256", "1K", "4K", "16K", "64K", "256K", "1M"]
        },
        "system": [{
            "matches": { "host": "morello-hybrid" },
            "host_system": {
                "name": "hybrid-kernel",
                "kernel": "GENERIC-NODEBUG",
                "arch": "arm64",
                "kernelabi": "hybrid",
                "userabi": "benchmark"
            }
        }, {
            "matches": { "host": "morello-benchmark" },
            "host_system": {
                "name": "benchmark-kernel",
                "kernel": "GENERIC-MORELLO-PURECAP-BENCHMARK-NODEBUG",
                "arch": "arm64",
                "kernelabi": "benchmark",
                "userabi": "benchmark"
            }
        }],
        "command_hooks": {
            "setup": [{
                "matches": {},
                "commands": [
                    "sysctl security.cheri.runtime_revocation_default=0",
                    "sysctl security.cheri.lib_based_c18n_default=0",
                    "[ -z \"$(ifconfig lo2)\" ] && ifconfig lo2 create",
                    "ifconfig lo2 mtu 1500 up",
                    "ifconfig lo2 10.0.0.1 netmask 255.255.255.0"
                ]
            }]
        },
        "generators": [{
            "handler": "iperf.exec",
            "task_options": {
                "server_addr": "10.0.0.1",
                "server_cpu": 0,
                "client_cpu": 1,
                "buffer_size": "{bufsize}",
                "transfer_limit": "1G",
                "streams": 1
            }
        }]
    }
}
