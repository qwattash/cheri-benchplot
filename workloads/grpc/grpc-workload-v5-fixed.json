{
    "version": "1.0",
    "bundle_results": true,
    "benchmark_config": {
        "name": "grpc-qps-c18n",
        "desc": "QPS throughput benchmark revocation + fixed message count varying c18n, c18n policy, c18n fastpath, msg size",
        "iterations": 5,
        "parameterize": {
            "host": ["vcu118", "toooba", "morello"],
            "c18n": ["enable", "disable"],
            "c18n_policy": ["none", "custom"],
            "c18n_fastpath": ["enable", "disable"],
            "msg_size": [64, 512, 4096, 32768, 262144, 2097152]
        },
        "parameterize_options": {
            "skip": [
                {"c18n": "disable", "c18n_policy": "custom"},
                {"c18n": "disable", "c18n_fastpath": "enable"}
            ],
            "derived": {
                "env_c18n_policy_var": [{
                    "matches": {
                        "c18n": "enable", "c18n_policy": "custom", "host": "morello"
                    },
                    "value": "LD_64CB_COMPARTMENT_POLICY"
                }, {
                    "matches": {
                        "c18n": "enable", "c18n_policy": "custom", "host": "vcu118"
                    },
                    "value": "LD_COMPARTMENT_POLICY"
                }, {
                    "matches": {
                        "c18n": "enable", "c18n_policy": "custom", "host": "toooba"
                    },
                    "value": "LD_COMPARTMENT_POLICY"
                }, {
                    "matches": { "c18n": "disable" },
                    "value": "NO_COMPARTMENT_POLICY"
                }, {
                    "matches": { "c18n_policy": "none" },
                    "value": "NO_COMPARTMENT_POLICY"
                }],
                "env_c18n_policy": [{
                    "matches": { "c18n_policy": "none" },
                    "value": ""
                }, {
                    "matches": { "c18n_policy": "custom" },
                    "value": "../../assets/grpc-policy.txt"
                }],
                "env_c18n_fastpath_var": [{
                    "matches": {
                        "c18n": "enable", "c18n_fastpath": "disable", "host": "morello"
                    },
                    "value": "LD_64CB_COMPARTMENT_NO_FAST_PATH"
                }, {
                    "matches": {
                        "c18n": "enable", "c18n_fastpath": "disable", "host": "vcu118"
                    },
                    "value": "LD_COMPARTMENT_NO_FAST_PATH"
                }, {
                    "matches": {
                        "c18n": "enable", "c18n_fastpath": "disable", "host": "toooba"
                    },
                    "value": "LD_COMPARTMENT_NO_FAST_PATH"
                }, {
                    "matches": { "c18n": "enable", "c18n_fastpath": "enable" },
                    "value": "_LD_COMPARTMENT_NO_FAST_PATH"
                }, {
                    "matches": { "c18n": "disable" },
                    "value": "_LD_COMPARTMENT_NO_FAST_PATH"
                }],
                "env_c18n_fastpath": [{
                    "matches": { "c18n_fastpath": "enable" },
                    "value": "0"
                }, {
                    "matches": { "c18n_fastpath": "disable" },
                    "value": "1"
                }],
                "driver_cpu": [{
                    "matches": { "host": "vcu118" },
                    "value": 2
                }, {
                    "matches": { "host": "toooba" },
                    "value": 1
                }, {
                    "matches": { "host": "morello" },
                    "value": 2
                }]
            }
        },
        "system": [{
            "matches": { "host": "vcu118" },
            "host_system": {
                "name": "cheribsd-x730",
                "kernel": "CHERI-PURECAP-PRIME-NODEBUG",
                "arch": "riscv64",
                "kernelabi": "purecap",
                "userabi": "purecap"
            }
        }, {
            "matches": { "host": "toooba" },
            "host_system": {
                "name": "cheribsd-toooba",
                "kernel": "CHERI-PURECAP-PRIME-NODEBUG",
                "arch": "riscv64",
                "kernelabi": "purecap",
                "userabi": "purecap"
            }
        }, {
            "matches": { "host": "morello" },
            "host_system": {
                "name": "cheribsd-morello",
                "kernel": "CHERI-MORELLO-BENCHMARK-NODEBUG",
                "arch": "arm64",
                "kernelabi": "benchmark",
                "userabi": "benchmark"
            }
        }],
        "command_hooks": {
            "setup": [{
                "matches": {},
                "commands": [
                    "sysctl security.cheri.runtime_revocation_default=1",
                    "sysctl security.cheri.lib_based_c18n_default=0"
                ]
            }]
        },
        "generators": [{
            "handler": "qps.exec",
            "task_options": {
                "qps_path": "/usr/local/riscv64-purecap/bin",
                "scenario_file": "sync-workload-fixed.template.json",
                "server_cpu": [0],
                "client_cpu": [1],
                "driver_cpu": ["{driver_cpu}"],
                "server_procctl_args": ["-m", "cheric18n", "-s", "{c18n}"],
                "client_procctl_args": ["-m", "cheric18n", "-s", "{c18n}"],
                "server_env": [
                    "{env_c18n_policy_var}={env_c18n_policy}",
                    "{env_c18n_fastpath_var}={env_c18n_fastpath}"
                ],
                "client_env": [
                    "{env_c18n_policy_var}={env_c18n_policy}",
                    "{env_c18n_fastpath_var}={env_c18n_fastpath}"
                ],
                "scenario_template_context": {
                    "warmup_time": 0,
                    "msg_limit": 50000,
                    "msg_size": "{msg_size}",
                    "channels": 1,
                    "outstanding_rpcs": 8
                }
            }
        }]
    },
    "assets": {
        "scenarios": { "action": "copy", "src": "assets/" }
    }
}
