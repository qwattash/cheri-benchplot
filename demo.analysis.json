{
    "plot": {
        "plot_output_format": ["pdf"]
    },
    "baseline": { "host": "morello", "revocation": "disable" },
    "tasks": [{
        "handler": "analysis.dynamic",
        "task_options": {
            "broadcast": [{
                "handler": "timing.bar-plot-slice",
                "task_options": {
                    "dependent_variable": "times",
                    "tile_aspect": 2.0,
                    "tile_col": "<revocation>",
                    "tile_xaxis": "<target>"
                }
            }],
            "fixed_axes": []
        }
    }]
}
